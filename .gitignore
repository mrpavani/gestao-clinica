# .gitignore for PHP Project

# Dependencies
/vendor/

# Configuration (must be created manually on the server)
/config/config.php

# Logs and temporary files
*.log
/tmp/
.cache/

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Database files (if local)
*.sqlite
*.db

# Production build artifacts
/production_build/

# Test files (should not go to production)
*.spec.ts
*.spec.js

# Backup files
*.bak

# Local development SQL scripts
local_db_schema.sql
migration_pwd_reset.sql
production_db_update.sql
